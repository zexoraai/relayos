{
  "name": "email-ingestion-service",
  "version": "1.0.0",
  "description": "Production-ready Email Ingestion Service using IMAP",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:api": "node dist/apiProcess.js",
    "start:workers": "node dist/workersProcess.js",
    "dev": "ts-node src/index.ts",
    "dev:api": "ts-node src/apiProcess.ts",
    "dev:workers": "ts-node src/workersProcess.ts",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "ts-node evals/run.ts",
    "eval:extraction": "ts-node evals/run.ts data-extraction"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.1.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "imapflow": "^1.0.150",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mailparser": "^3.6.5",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "pino": "^8.16.2",
    "prom-client": "^15.1.0",
    "sanitize-filename": "^1.6.3",
    "uuid": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  }
}
