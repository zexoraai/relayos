# ============================================================
# RelayOS Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL) ---
# Either set DATABASE_URL (cloud platforms like Railway, Heroku) OR the split vars below.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=email_ingestion
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# --- Redis ---
# Either set REDIS_URL OR the split vars below.
# REDIS_URL=redis://default:pass@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- IMAP (Email Ingestion) — optional in cloud deploys ---
# Leave IMAP_HOST blank to disable the email ingestion worker.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLLING_INTERVAL_MS=30000

# --- API Server ---
# Railway / cloud platforms inject PORT — it takes precedence over API_PORT.
API_PORT=3001
METRICS_PORT=9090

# --- Auth ---
JWT_SECRET=your-random-secret-here
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=32-byte-hex-string-for-aes-256

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (optional fallback) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
LLM_FALLBACK_ENABLED=false
LLM_PROVIDER_ORDER=openai,anthropic

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- Shopify Webhook ---
SHOPIFY_WEBHOOK_SECRET=

# --- Fulfillment ---
FULFILLMENT_POLLING_INTERVAL_MS=300000
FULFILLMENT_WORKER_TICK_MS=30000

# --- Marketing ---
MARKETING_WORKER_TICK_MS=60000

# --- Outbox Relay ---
OUTBOX_RELAY_TICK_MS=5000
OUTBOX_RELAY_BATCH_SIZE=50
OUTBOX_RELAY_MAX_ATTEMPTS=10

# --- Queue ---
QUEUE_NAME=email-processing
QUEUE_CONCURRENCY=5

# --- Storage ---
STORAGE_PATH=./storage/attachments

# --- Logging ---
LOG_LEVEL=info

# --- Runtime ---
NODE_ENV=production
